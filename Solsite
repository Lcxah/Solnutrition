</nav>

<!-- HERO -->
<div class="hero">
  <svg class="logo-svg" width="80" height="80" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
    <circle cx="32" cy="32" r="28" fill="none" stroke="#BA7517" stroke-width="1.5"/>
    <circle cx="32" cy="32" r="20" fill="#2C2C2A"/>
    <path d="M32 16 Q44 16 44 32 Q44 48 32 48 Q22 48 20 38 Q18 28 26 22 Q31 18 34 26 Q37 32 32 36 Q28 38 26 34" fill="none" stroke="#EF9F27" stroke-width="2" stroke-linecap="round"/>
  </svg>
  <p class="eyebrow">Montréal · Clean fuel · No compromise</p>
  <h1>Fuel the <em>real</em> you.</h1>
  <p class="hero-sub">A protein bar built from whole food ingredients. Nothing artificial. Nothing hidden. Made in Montréal for men who give a damn about what they put in their body.</p>
  <div class="badges">
    <span class="badge">No seed oils</span>
    <span class="badge">No whey</span>
    <span class="badge">No artificial sweeteners</span>
    <span class="badge">17g protein</span>
    <span class="badge">8 real ingredients</span>
    <span class="badge">Made in Montréal</span>
  </div>
  <div class="waitlist-wrap" id="waitlist">
    <div class="waitlist-form" id="wform">
      <input type="email" id="email-in" placeholder="your@email.com"/>
      <button class="waitlist-btn" onclick="joinList()">Join the waitlist</button>
    </div>
    <p class="waitlist-hint" id="whint">Get 10% off your first order — no spam, ever.</p>
    <div class="success" id="wsuccess">You're on the list. Sol drops soon — we'll reach out first.</div>
  </div>
</div>

<div class="divider"></div>

<!-- INGREDIENTS -->
<div class="section">
  <p class="sec-label">What's inside — click each ingredient</p>
  <div class="ing-grid">
    <div class="ing-card active" onclick="showIng(0)">
      <div class="ing-icon">🌿</div>
      <div class="ing-name">Hemp protein</div>
      <div class="ing-role">Primary protein</div>
    </div>
    <div class="ing-card" onclick="showIng(1)">
      <div class="ing-icon">🌊</div>
      <div class="ing-name">Spirulina</div>
      <div class="ing-role">Superfood boost</div>
    </div>
    <div class="ing-card" onclick="showIng(2)">
      <div class="ing-icon">🌴</div>
      <div class="ing-name">Medjool dates</div>
      <div class="ing-role">Natural binder</div>
    </div>
    <div class="ing-card" onclick="showIng(3)">
      <div class="ing-icon">🍫</div>
      <div class="ing-name">Raw cacao</div>
      <div class="ing-role">Flavour + antioxidants</div>
    </div>
    <div class="ing-card" onclick="showIng(4)">
      <div class="ing-icon">🥜</div>
      <div class="ing-name">Almond butter</div>
      <div class="ing-role">Healthy fats</div>
    </div>
    <div class="ing-card" onclick="showIng(5)">
      <div class="ing-icon">🍯</div>
      <div class="ing-name">Raw honey</div>
      <div class="ing-role">Natural sweetener</div>
    </div>
  </div>
  <div class="ing-detail">
    <h3 id="ing-title">Hemp protein</h3>
    <p id="ing-text">A complete plant protein with all essential amino acids. Hemp is easier to digest than whey, contains omega-3 and omega-6 fatty acids, and causes zero gut issues. It carries the bulk of Sol's 17g protein per bar — clean, natural, Canadian-grown.</p>
  </div>
</div>

<div class="divider"></div>

<!-- MACROS -->
<div class="section">
  <p class="sec-label">Nutrition per bar — 60g</p>
  <div class="macro-grid">
    <div class="macro-card">
      <div class="macro-unit">grams</div>
      <div class="macro-val">17</div>
      <div class="macro-label">Protein</div>
    </div>
    <div class="macro-card">
      <div class="macro-unit">kcal</div>
      <div class="macro-val">220</div>
      <div class="macro-label">Calories</div>
    </div>
    <div class="macro-card">
      <div class="macro-unit">grams</div>
      <div class="macro-val">9</div>
      <div class="macro-label">Healthy fats</div>
    </div>
    <div class="macro-card">
      <div class="macro-unit">grams</div>
      <div class="macro-val">4</div>
      <div class="macro-label">Fibre</div>
    </div>
  </div>
</div>

<div class="divider"></div>

<!-- VS -->
<div class="section">
  <p class="sec-label">Sol vs the rest</p>
  <div class="vs-grid">
    <div class="vs-card vs-them">
      <div class="vs-head">Most protein bars</div>
      <div class="vs-item"><i class="xi">✕</i> Sucralose or erythritol</div>
      <div class="vs-item"><i class="xi">✕</i> Sunflower or canola oil</div>
      <div class="vs-item"><i class="xi">✕</i> Whey or soy isolate</div>
      <div class="vs-item"><i class="xi">✕</i> "Natural flavours" — anything</div>
      <div class="vs-item"><i class="xi">✕</i> 20+ ingredient list</div>
      <div class="vs-item"><i class="xi">✕</i> Made in a factory lab</div>
    </div>
    <div class="vs-card vs-us">
      <div class="vs-head">Sol Nutrition</div>
      <div class="vs-item"><i class="ci">✓</i> Raw honey + medjool dates</div>
      <div class="vs-item"><i class="ci">✓</i> Zero seed oils — ever</div>
      <div class="vs-item"><i class="ci">✓</i> Hemp + spirulina protein</div>
      <div class="vs-item"><i class="ci">✓</i> Every ingredient named</div>
      <div class="vs-item"><i class="ci">✓</i> 8 real ingredients only</div>
      <div class="vs-item"><i class="ci">✓</i> Made in Montréal, QC</div>
    </div>
  </div>
</div>

<div class="divider"></div>

<!-- FLAVOURS -->
<div class="flavour-section">
  <p class="sec-label" style="text-align:center;">Flavours</p>
  <h2>Three bars. Zero compromise.</h2>
  <p>Each flavour is built on the same clean base. Click to explore.</p>
  <div class="flavour-pills">
    <button class="fl-pill fl-1 sel" onclick="showFl(0,this)">Cacao + Hemp</button>
    <button class="fl-pill fl-2" onclick="showFl(1,this)">Almond + Miel</button>
    <button class="fl-pill fl-3" onclick="showFl(2,this)">Spirulina + Lime</button>
  </div>
  <div class="fl-detail">
    <h3 id="fl-name">Cacao + Hemp</h3>
    <p id="fl-desc">The launch bar. Rich, dark, grounding. Raw cacao and hemp seeds hit hard — this is the one for the guy who doesn't need it to taste like a candy bar. Real chocolate flavour from real cacao. Launching first.</p>
  </div>
  <a href="#waitlist" class="nav-btn" style="display:inline-block;">Get notified at launch</a>
</div>

<div class="divider"></div>

<!-- STORY -->
<div class="story-section">
  <p class="sec-label">The story</p>
  <blockquote>"Most bars are engineered in a lab.<br><em>Sol is built from the ground up.</em>"</blockquote>
  <p>Sol started in a Montréal kitchen with one question — why does every protein bar read like a chemistry experiment? My family has been in food distribution for years. I know what goes into most products. It's not great.</p>
  <p>So I built the bar I actually want to eat. Hemp protein and spirulina for real plant fuel. Medjool dates to bind it naturally. Raw cacao for honest chocolate flavour. No seed oils. No sweeteners. No ingredients you need a chemistry degree to understand.</p>
  <p style="color:#BA7517;font-weight:500;">Sol. Made in Montréal. Coming soon.</p>
</div>

<div class="divider"></div>

<!-- FOOTER -->
<footer>
  <span class="footer-logo">SOL</span>
  <span class="footer-copy">Fabriqué à Montréal, Québec &nbsp;·&nbsp; solnutrition.ca</span>
  <div class="footer-links">
    <a href="https://instagram.com/solnutrition" target="_blank">Instagram</a>
    <a href="https://tiktok.com/@solnutrition" target="_blank">TikTok</a>
    <a href="mailto:hello@solnutrition.ca">Contact</a>
  </div>
</footer>

<script>
const ings=[
  {t:'Hemp protein',p:'A complete plant protein with all essential amino acids. Hemp is easier to digest than whey, contains omega-3 and omega-6 fatty acids, and causes zero gut issues. It carries the bulk of Sol\'s 17g protein per bar — clean, natural, Canadian-grown.'},
  {t:'Spirulina',p:'One of the most nutrient-dense foods on earth. Spirulina adds 5–8g of plant protein per bar plus iron, B vitamins, and powerful antioxidants. It\'s the ingredient that separates Sol from every other bar on the shelf.'},
  {t:'Medjool dates',p:'Nature\'s binder and sweetener in one. Medjool dates hold the bar together without glycerin, tapioca syrup, or any processed binder. They bring natural sugar, fibre, potassium, and magnesium — no processing required.'},
  {t:'Raw cacao',p:'Not cocoa powder — raw cacao. Cold-pressed from the cacao bean, retaining all the flavanols, magnesium, and antioxidants that processing destroys. The deepest, most honest chocolate flavour possible.'},
  {t:'Almond butter',p:'A source of monounsaturated fats, vitamin E, and magnesium. Almond butter gives Sol its texture and satiety. Healthy fat that keeps you full. No added oils, no emulsifiers. Just ground almonds.'},
  {t:'Raw honey',p:'Antimicrobial, rich in enzymes and trace minerals, and naturally sweet without the blood sugar spike of refined sugar. A touch of raw honey rounds the flavour without artificial sweeteners or sugar alcohols.'}
];
const fls=[
  {n:'Cacao + Hemp',d:'The launch bar. Rich, dark, grounding. Raw cacao and hemp seeds hit hard — this is the one for the guy who doesn\'t need it to taste like a candy bar. Real chocolate flavour from real cacao. Launching first.'},
  {n:'Almond + Miel',d:'Lighter, warmer, sweeter. Almond butter and raw honey lead — this is the bar for the guy who wants something approachable and satisfying without the intensity of dark cacao. Flavour 2 drops when batch 1 sells out.'},
  {n:'Spirulina + Lime',d:'Bold, green, citrus. Not for everyone — that\'s the point. Bright lime zest cuts through the spirulina earthiness. For the guy who goes all-in on clean eating and wants something that proves it. Flavour 3.'}
];

function showIng(i){
  document.querySelectorAll('.ing-card').forEach((c,x)=>c.classList.toggle('active',x===i));
  document.getElementById('ing-title').textContent=ings[i].t;
  document.getElementById('ing-text').textContent=ings[i].p;
}
function showFl(i,el){
  document.querySelectorAll('.fl-pill').forEach(p=>p.classList.remove('sel'));
  el.classList.add('sel');
  document.getElementById('fl-name').textContent=fls[i].n;
  document.getElementById('fl-desc').textContent=fls[i].d;
}
function joinList(){
  const v=document.getElementById('email-in').value.trim();
  if(!v||!v.includes('@')){
    document.getElementById('email-in').style.borderColor='#E24B4A';
    return;
  }
  document.getElementById('wform').style.display='none';
  document.getElementById('whint').style.display='none';
  document.getElementById('wsuccess').style.display='block';
}
</script>
