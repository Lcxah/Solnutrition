<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Sol Nutrition — Fuel the real you</title>
<meta name="description" content="A clean protein bar built from whole food ingredients. No seed oils. No whey. No sweeteners. Made in Montréal."/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:'DM Sans',sans-serif;background:#2C2C2A;color:#FAEEDA;}

/* NAV */
nav{display:flex;align-items:center;justify-content:space-between;padding:20px 40px;border-bottom:0.5px solid rgba(250,238,218,0.1);position:sticky;top:0;background:#2C2C2A;z-index:100;}
.nav-logo{display:flex;align-items:center;gap:12px;text-decoration:none;}
.nav-logo-text{font-family:'Playfair Display',serif;font-size:22px;font-weight:700;color:#FAEEDA;letter-spacing:4px;}
.nav-sub{font-size:9px;font-weight:300;color:#EF9F27;letter-spacing:3px;display:block;margin-top:-3px;}
.nav-btn{background:#BA7517;border:none;border-radius:8px;padding:10px 22px;color:#FAEEDA;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:background 0.2s;text-decoration:none;}
.nav-btn:hover{background:#EF9F27;}

/* HERO */
.hero{padding:80px 40px 64px;text-align:center;max-width:700px;margin:0 auto;}
.eyebrow{font-size:11px;letter-spacing:0.22em;color:#BA7517;text-transform:uppercase;margin-bottom:24px;}
.hero h1{font-family:'Playfair Display',serif;font-size:60px;font-weight:700;line-height:1.05;margin-bottom:16px;}
.hero h1 em{font-style:italic;color:#EF9F27;}
.hero-sub{font-size:16px;font-weight:300;color:rgba(250,238,218,0.6);line-height:1.75;margin-bottom:36px;}
.badges{display:flex;justify-content:center;flex-wrap:wrap;gap:8px;margin-bottom:40px;}
.badge{background:rgba(250,238,218,0.06);border:0.5px solid rgba(250,238,218,0.14);color:rgba(250,238,218,0.65);font-size:11px;padding:6px 16px;border-radius:20px;font-weight:300;}

/* WAITLIST */
.waitlist-wrap{max-width:460px;margin:0 auto;}
.waitlist-form{display:flex;gap:8px;margin-bottom:10px;}
.waitlist-form input{flex:1;background:rgba(250,238,218,0.07);border:0.5px solid rgba(250,238,218,0.18);border-radius:8px;padding:14px 18px;color:#FAEEDA;font-family:'DM Sans',sans-serif;font-size:14px;outline:none;transition:border-color 0.2s;}
.waitlist-form input::placeholder{color:rgba(250,238,218,0.3);}
.waitlist-form input:focus{border-color:#BA7517;}
.waitlist-btn{background:#BA7517;border:none;border-radius:8px;padding:14px 24px;color:#FAEEDA;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;cursor:pointer;white-space:nowrap;transition:background 0.2s;}
.waitlist-btn:hover{background:#EF9F27;}
.waitlist-hint{font-size:11px;color:rgba(250,238,218,0.3);text-align:center;}
.success{display:none;background:rgba(29,158,117,0.12);border:0.5px solid #1D9E75;border-radius:8px;padding:14px 20px;color:#5DCAA5;font-size:14px;text-align:center;}

/* DIVIDER */
.divider{height:0.5px;background:rgba(250,238,218,0.08);margin:0 40px;}

/* SECTIONS */
.section{padding:64px 40px;max-width:900px;margin:0 auto;}
.sec-label{font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:#BA7517;margin-bottom:24px;font-weight:400;}

/* INGREDIENTS */
.ing-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:20px;}
.ing-card{background:rgba(250,238,218,0.04);border:0.5px solid rgba(250,238,218,0.1);border-radius:10px;padding:18px 14px;cursor:pointer;transition:border-color 0.2s,background 0.2s;}
.ing-card:hover,.ing-card.active{border-color:#BA7517;background:rgba(186,117,23,0.1);}
.ing-icon{font-size:24px;margin-bottom:10px;}
.ing-name{font-size:13px;font-weight:500;color:#FAEEDA;margin-bottom:3px;}
.ing-role{font-size:11px;color:#BA7517;font-weight:300;}
.ing-detail{background:rgba(186,117,23,0.07);border:0.5px solid rgba(186,117,23,0.2);border-radius:10px;padding:20px 22px;margin-top:4px;}
.ing-detail h3{font-family:'Playfair Display',serif;font-size:18px;color:#EF9F27;margin-bottom:8px;}
.ing-detail p{font-size:14px;color:rgba(250,238,218,0.65);line-height:1.75;}

/* MACROS */
.macro-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;}
.macro-card{background:rgba(250,238,218,0.04);border:0.5px solid rgba(250,238,218,0.1);border-radius:10px;padding:20px 12px;text-align:center;}
.macro-unit{font-size:11px;color:#BA7517;margin-bottom:2px;}
.macro-val{font-family:'Playfair Display',serif;font-size:36px;font-weight:700;color:#EF9F27;line-height:1;}
.macro-label{font-size:12px;color:rgba(250,238,218,0.4);margin-top:6px;font-weight:300;}

/* VS */
.vs-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.vs-card{border-radius:12px;padding:24px 20px;}
.vs-them{background:rgba(250,238,218,0.03);border:0.5px solid rgba(250,238,218,0.08);}
.vs-us{background:rgba(186,117,23,0.08);border:0.5px solid rgba(186,117,23,0.3);}
.vs-head{font-size:10px;letter-spacing:0.14em;text-transform:uppercase;margin-bottom:16px;}
.vs-them .vs-head{color:rgba(250,238,218,0.25);}
.vs-us .vs-head{color:#EF9F27;}
.vs-item{display:flex;align-items:flex-start;gap:10px;margin-bottom:10px;font-size:13px;line-height:1.5;}
.vs-them .vs-item{color:rgba(250,238,218,0.35);}
.vs-us .vs-item{color:rgba(250,238,218,0.85);}
.xi{color:#E24B4A;flex-shrink:0;font-style:normal;}
.ci{color:#1D9E75;flex-shrink:0;font-style:normal;}

/* FLAVOURS */
.flavour-section{padding:64px 40px;text-align:center;max-width:700px;margin:0 auto;}
.flavour-section h2{font-family:'Playfair Display',serif;font-size:36px;color:#FAEEDA;margin-bottom:10px;}
.flavour-section p{font-size:14px;color:rgba(250,238,218,0.45);font-weight:300;line-height:1.7;margin-bottom:32px;}
.flavour-pills{display:flex;justify-content:center;gap:10px;flex-wrap:wrap;margin-bottom:28px;}
.fl-pill{padding:10px 24px;border-radius:20px;font-size:13px;font-weight:500;cursor:pointer;transition:all 0.2s;border:0.5px solid;font-family:'DM Sans',sans-serif;}
.fl-1{background:rgba(99,56,6,0.2);border-color:#633806;color:#EF9F27;}
.fl-1.sel,.fl-1:hover{background:#633806;border-color:#BA7517;}
.fl-2{background:rgba(186,117,23,0.1);border-color:#854F0B;color:#EF9F27;}
.fl-2.sel,.fl-2:hover{background:#854F0B;border-color:#EF9F27;}
.fl-3{background:rgba(8,80,65,0.15);border-color:#085041;color:#5DCAA5;}
.fl-3.sel,.fl-3:hover{background:#085041;border-color:#1D9E75;}
.fl-detail{background:rgba(250,238,218,0.04);border:0.5px solid rgba(250,238,218,0.1);border-radius:12px;padding:24px 28px;max-width:420px;margin:0 auto 32px;transition:all 0.3s;}
.fl-detail h3{font-family:'Playfair Display',serif;font-size:20px;color:#EF9F27;margin-bottom:8px;}
.fl-detail p{font-size:13px;color:rgba(250,238,218,0.55);line-height:1.7;}

/* STORY */
.story-section{padding:64px 40px;max-width:700px;margin:0 auto;}
.story-section blockquote{font-family:'Playfair Display',serif;font-size:26px;font-weight:700;color:#FAEEDA;line-height:1.35;margin-bottom:20px;}
.story-section blockquote em{color:#EF9F27;font-style:italic;}
.story-section p{font-size:14px;color:rgba(250,238,218,0.55);line-height:1.8;margin-bottom:14px;}

/* FOOTER */
footer{padding:32px 40px;border-top:0.5px solid rgba(250,238,218,0.08);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;}
.footer-logo{font-family:'Playfair Display',serif;font-size:18px;color:#FAEEDA;letter-spacing:4px;}
.footer-copy{font-size:11px;color:rgba(250,238,218,0.25);font-weight:300;}
.footer-links{display:flex;gap:20px;}
.footer-links a{font-size:12px;color:#BA7517;text-decoration:none;font-weight:300;transition:color 0.2s;}
.footer-links a:hover{color:#EF9F27;}

/* LOGO SVG */
.logo-svg{display:block;margin:0 auto 36px;}

@media(max-width:600px){
  .hero h1{font-size:40px;}
  .macro-grid{grid-template-columns:repeat(2,1fr);}
  .vs-grid{grid-template-columns:1fr;}
  nav{padding:16px 20px;}
  .section,.story-section,.flavour-section{padding:48px 20px;}
  .divider{margin:0 20px;}
  footer{padding:24px 20px;flex-direction:column;text-align:center;}
  .waitlist-form{flex-direction:column;}
}
</style>
</head>
<body>

<nav>
  <a class="nav-logo" href="#">
    <svg width="36" height="36" viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
      <circle cx="32" cy="32" r="28" fill="none" stroke="#BA7517" stroke-width="2"/>
      <circle cx="32" cy="32" r="20" fill="#2C2C2A"/>
      <path d="M32 16 Q44 16 44 32 Q44 48 32 48 Q22 48 20 38 Q18 28 26 22 Q31 18 34 26 Q37 32 32 36 Q28 38 26 34" fill="none" stroke="#EF9F27" stroke-width="2.2" stroke-linecap="round"/>
    </svg>
    <div>
      <span class="nav-logo-text">SOL</span>
      <span class="nav-sub">NUTRITION</span>
